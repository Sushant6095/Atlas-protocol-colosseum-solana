# --- Web ---
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_HELIUS_API_KEY=
NEXT_PUBLIC_DEFAULT_VAULT=

# --- Orchestrator ---
ATLAS_RPC_URL=https://api.mainnet-beta.solana.com
ATLAS_JITO_URL=https://mainnet.block-engine.jito.wtf
ATLAS_KEYPAIR=/path/to/orchestrator-keypair.json
ATLAS_VAULT_ID=
ATLAS_MODEL_PATH=./prover/model/atlas-v1.bin
ATLAS_POLL_SECS=21600
ATLAS_MIN_DRIFT_BPS=50

# --- Prover ---
SP1_PROVER=cpu      # or `cuda` on RunPod GPU
RUST_LOG=info,atlas_orchestrator=debug
