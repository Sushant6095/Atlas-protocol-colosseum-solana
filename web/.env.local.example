# Copy to .env.local

NEXT_PUBLIC_CLUSTER=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# WalletConnect — get free project ID at https://cloud.walletconnect.com
# Once set, "WalletConnect" appears in the wallet modal as a QR-pairable wallet.
# Mobile wallets that support WC: Phantom, Solflare, Trust, Backpack, Glow.
# (MetaMask Mobile does NOT sign Solana — use Phantom Mobile via WC instead.)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional treasury — leave unset for safe self-transfer demo
# NEXT_PUBLIC_ATLAS_TREASURY=
